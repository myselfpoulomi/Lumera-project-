{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",

    /* Project Structure */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Strictness */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    /* Interop */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Performance */
    "skipLibCheck": true,

    /* Source Maps */
    "sourceMap": true,

    /* JSON imports */
    "resolveJsonModule": true,

    /* Type Definitions */
    "types": ["node"],

    /* Force consistent casing */
    "forceConsistentCasingInFileNames": true
  },

  "include": ["src"],

  "exclude": [
    "node_modules",
    "dist",
    "prisma.config.ts"
  ]
}